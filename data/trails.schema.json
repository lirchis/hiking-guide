{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lirchis/hiking-guide/data/trails.schema.json",
  "title": "Hiking Guide dataset",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "trails"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "sourceUrl", "updatedAt", "includedCount", "totalCount"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "sourceUrl": { "type": "string", "format": "uri" },
        "updatedAt": { "type": "string", "format": "date" },
        "includedCount": { "type": "integer", "minimum": 0 },
        "totalCount": { "type": "integer", "minimum": 0 }
      }
    },
    "trails": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "scope",
          "region",
          "location",
          "distanceKmMin",
          "distanceKmMax",
          "distanceText",
          "durationText",
          "difficultyScore",
          "bestSeason",
          "experience",
          "sceneryScore",
          "routeScore",
          "status",
          "notice"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "name": { "type": "string", "minLength": 1 },
          "scope": { "enum": ["greater-bay-area", "china"] },
          "region": { "type": "string", "minLength": 1 },
          "location": { "type": "string", "minLength": 1 },
          "distanceKmMin": { "type": "number", "minimum": 0 },
          "distanceKmMax": { "type": "number", "minimum": 0 },
          "distanceText": { "type": "string", "minLength": 1 },
          "durationText": { "type": "string", "minLength": 1 },
          "difficultyScore": { "type": "number", "minimum": 1, "maximum": 5 },
          "bestSeason": { "type": "string", "minLength": 1 },
          "experience": { "type": "string", "minLength": 1 },
          "sceneryScore": { "type": "number", "minimum": 1, "maximum": 5 },
          "routeScore": { "type": "number", "minimum": 1, "maximum": 5 },
          "status": {
            "enum": ["available", "verify", "reference", "closed"]
          },
          "notice": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
